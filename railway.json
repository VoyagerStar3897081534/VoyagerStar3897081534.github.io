{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "startCommand": "npm start",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "volumes": [
      {
        "name": "blog-data",
        "mountPath": "/app/data/blog"
      },
      {
        "name": "uploads-data",
        "mountPath": "/app/uploads"
      }
    ]
  }
}
